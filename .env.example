VITE_LLM_PROVIDER=gemini

VITE_GEMINI_MODEL=gemini-2.5-flash
# Public deployment recommendation:
# - Do NOT set VITE_GEMINI_API_KEY in production.
# - Users enter/verify their own Gemini key in the app access gate.

# Optional local-development OpenAI fallback:
# VITE_OPENAI_API_KEY=your_openai_key_here
# VITE_OPENAI_MODEL=gpt-5

# Optional NotebookLM bridge endpoint for authenticated notebook sync
VITE_NOTEBOOKLM_BRIDGE_URL=http://localhost:8787
